# Required — SQLite database file path used by Prisma
DATABASE_URL=file:./dev.db

# Optional in development — defaults to "dev-insecure-secret-change-this"
# JWT_SECRET=change-me-in-production

# Optional — enables OpenAI-powered ad concept generation (falls back to deterministic generator)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini
